# PostgreSQL connection string
DATABASE_URI=postgresql://portfolio:portfolio@localhost:5432/portfolio

# Secret key for Payload JWT — ganti dengan string acak panjang di production
PAYLOAD_SECRET=changeme_use_a_long_random_string

# URL CMS ini sendiri (dipakai Payload untuk generate absolute URL di admin)
SERVER_URL=http://localhost:3001

# Port server (opsional, default 3001)
PORT=3001
